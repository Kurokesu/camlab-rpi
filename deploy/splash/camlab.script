#
# Centered splash art on black. Boot adds a loader bar below it, shutdown and
# reboot show the static art only.

Window.SetBackgroundTopColor(0, 0, 0);
Window.SetBackgroundBottomColor(0, 0, 0);

logo = Image("splash.png");
logo_sprite = Sprite(logo);
logo_sprite.SetX(Window.GetWidth() / 2 - logo.GetWidth() / 2);
logo_sprite.SetY(Window.GetHeight() / 2 - logo.GetHeight() / 2);

progress_bg = Image("progress_bg.png");
progress_fill = Image("progress_fill.png");

bar_w = logo.GetWidth();
bar_x = Window.GetWidth() / 2 - bar_w / 2;
bar_y = Window.GetHeight() / 2 + logo.GetHeight() / 2 + 40;

is_boot = (Plymouth.GetMode() == "boot");

if (is_boot) {
    scaled_bg = progress_bg.Scale(bar_w, progress_bg.GetHeight());
    bg_sprite = Sprite(scaled_bg);
    bg_sprite.SetX(bar_x);
    bg_sprite.SetY(bar_y);
    bg_sprite.SetZ(1);

    fill_sprite = Sprite();
    fill_sprite.SetX(bar_x);
    fill_sprite.SetY(bar_y);
    fill_sprite.SetZ(2);
}

fun boot_progress_cb(duration, progress) {
    if (is_boot)
        fill_sprite.SetImage(progress_fill.Scale(progress * bar_w, progress_fill.GetHeight()));
}

Plymouth.SetBootProgressFunction(boot_progress_cb);
