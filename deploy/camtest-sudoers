#
# Rendered to /etc/sudoers.d/camtest by scripts/setup/config.sh (CAMTEST_USER
# substituted). Minimal, scoped NOPASSWD rights for the kiosk GUI:
#   - the config-write shim (managed block in config.txt)
#   - poweroff (both a sensor swap and operator shutdown power the box off)
# Nothing else. Installed with visudo -c validation.

CAMTEST_USER ALL=(root) NOPASSWD: /usr/local/bin/camtest-apply
CAMTEST_USER ALL=(root) NOPASSWD: /usr/bin/systemctl poweroff
