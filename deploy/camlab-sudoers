#
# Rendered to /etc/sudoers.d/camlab by scripts/setup/config.sh (substitutes
# CAMLAB_USER, validates with visudo -c). Minimal NOPASSWD rights for the
# kiosk GUI, exact commands only:
#   - config-write shim (managed block in config.txt)
#   - poweroff (both a sensor swap and operator shutdown power the box off)
#   - networking toggle (Settings dialog)

CAMLAB_USER ALL=(root) NOPASSWD: /usr/local/bin/camlab-apply
CAMLAB_USER ALL=(root) NOPASSWD: /usr/bin/systemctl poweroff --no-wall
CAMLAB_USER ALL=(root) NOPASSWD: /usr/local/bin/camlabctl net on
CAMLAB_USER ALL=(root) NOPASSWD: /usr/local/bin/camlabctl net off
